<!DOCTYPE html>
<html lang="pt-BR">

<body>

  <!-- INICIO - parte superior da pagina -->
  <%- include('./Partial/head') %>

  <header class="bg-primary superior d-flex flex-row p-3">
    <div class="flex-grow-1">
      <h1 class="fs-3"><i class="bi bi-list-ol"></i> Listas de Carros Estacionados</h1>
    </div>
    <div class="flex-grow-1 d-flex flex-row-reverse">

      <button type="button btn-primary" class="btn">
        <h1 class="fs-3 px-3">
          <i class="bi bi-person-circle"></i> login
        </h1>
      </button>

    </div>
  </header>

  <!-- FINAL - parte superior da pagina -->

  <!--INICIO -  meio da pagina-->
  <main class="container d-flex flex-column">


    <!-- botoes de criacao e exclusao de tarefas -->
    <div class="d-flex gap-3 my-3">
      <button type="button" class="btn btn-primary"> <i class="bi bi-plus"></i> Novo Resgistro</button>
      <button type="button" class="btn btn-primary"><i class="bi bi-trash"></i> Excluir Resgistro</button>
    </div>

    <!--INICIO -  tabela de tarefas -->
    <table class="container table table-striped">
      <thead>
        <tr>
          <th scope="col"></th>
          <th scope="col">#</th>
          <th scope="col">Dia</th>
          <th scope="col">Hora</th>
          <th scope="col">Descrição</th>
          <th scope="col">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% dados.forEach((tarefa,indice) => { %>
         <!-- INICIO DE UMA TAREFA -->
        <tr>
          <th scope="row"><input type="checkbox"></th>
          <th scope="row"><%= indice + 1 %></th>
          <td> <%= Registro.data %> </td>
          <td> <%= Registro.hora %> </td>
          <td> <%= Registro.descricao %> </td>
          <td>

            <button type="button" class="btn btn-primary">
              <i class="bi bi-pencil"></i>
              Editar Resgistro
            </button>

          </td>
        </tr>
           

       <% })%>
       
       

        <!-- AS NOVAS TAREFAS DEVEM SER INCLUIDAS AQUI -->

      </tbody>
    </table>
    <!--FINAL -  tabela de tarefas -->

  </main>
  <!--FIM -  meio da pagina-->

  <!-- rodapé -->
  <footer>
    <div class="row">
      <div class="col-12 bg-primary py-3">
        <h1 class="titulo text-center fs-5 "><i class="bi bi-cc-circle"></i> Todos o direitos reservados</h1>
      </div>
    </div>

  </footer>
  <!--rodapé -->

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
    crossorigin="anonymous"></script>
</body>

</html>